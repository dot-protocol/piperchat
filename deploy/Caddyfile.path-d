# ─────────────────────────────────────────────────────────────────────────────
# openclaw.mevici.com — OpenClaw gateway (WebSocket + CORS)
# ─────────────────────────────────────────────────────────────────────────────
http://openclaw.mevici.com:8090 {
    @options_oc method OPTIONS
    handle @options_oc {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Authorization, Content-Type, x-openclaw-agent-id"
        respond 204
    }

    handle {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Authorization, Content-Type, x-openclaw-agent-id"

        reverse_proxy localhost:18789 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            lb_policy least_conn
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# kin.mevici.com — Kin server (WebSocket)
# ─────────────────────────────────────────────────────────────────────────────
http://kin.mevici.com:8090 {
    handle /ws {
        reverse_proxy localhost:4041 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle {
        reverse_proxy localhost:4041 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# sandbox.mevici.com — static files from /opt/sandbox/files
# ─────────────────────────────────────────────────────────────────────────────
http://sandbox.mevici.com:8090 {
    root * /opt/sandbox/files
    file_server
}

# ─────────────────────────────────────────────────────────────────────────────
# demo.axxis.world — static files from /opt/axxis/demo
# ─────────────────────────────────────────────────────────────────────────────
http://demo.axxis.world:8090 {
    header Access-Control-Allow-Origin "*"
    header Cache-Control "public, max-age=60"

    root * /opt/axxis/demo
    file_server {
        index index.html
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# id.axxis.world — identity-dns service (CORS)
# ─────────────────────────────────────────────────────────────────────────────
http://id.axxis.world:8090 {
    @options_id method OPTIONS
    respond @options_id 204

    header Access-Control-Allow-Origin "*"
    header Access-Control-Allow-Methods "GET, POST, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, Authorization"

    handle {
        reverse_proxy localhost:8896 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# drop.axxis.world — DOTdrop via Sentinel (large uploads: 110MB)
# ─────────────────────────────────────────────────────────────────────────────
http://drop.axxis.world:8090 {
    @llms path /llms.txt /drop/llms.txt

    handle @llms {
        root * /opt/room
        rewrite * /llms.txt
        file_server
        header Content-Type text/plain
    }

    handle {
        request_body {
            max_size 110MB
        }
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            flush_interval -1
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# room.axxis.world — The Council/Room via Sentinel (WebSocket)
# ─────────────────────────────────────────────────────────────────────────────
http://room.axxis.world:8090 {
    handle {
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            flush_interval -1
        }
    }
}

# ─────────────────────────────────────────────────────────────────────────────
# DEFAULT SERVER (catch-all for direct IP / unknown hosts)
# Mirrors the nginx default_server block: sentinel paths + VPS OK response
# ─────────────────────────────────────────────────────────────────────────────
:8090 {
    handle /sentinel/* {
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /room/* {
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            flush_interval -1
        }
    }

    handle /p2p/* {
        reverse_proxy localhost:4100 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            flush_interval -1
        }
    }

    handle /player {
        reverse_proxy localhost:8877 {
            header_up Host {host}
        }
    }

    handle /dotdrop/* {
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            flush_interval -1
        }
    }

    handle /dotpost/* {
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            flush_interval -1
        }
    }

    handle /post/* {
        redir /post/index.html 302
    }

    handle /post/index.html {
        root * /opt/room
        rewrite * /dotpost.html
        file_server
        header Content-Type text/html
    }

    handle /drop/* {
        request_body {
            max_size 110MB
        }
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            flush_interval -1
        }
    }

    handle /oracle-spec/* {
        header Access-Control-Allow-Origin "*"
        reverse_proxy localhost:4090 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle {
        respond "VPS OK" 200
    }
}
