}

# ─────────────────────────────────────────────────────────────────────────────
# monitor.piedpiper.fun — Netdata (ROCK 3: basicauth with bcrypt)
# ─────────────────────────────────────────────────────────────────────────────
http://monitor.piedpiper.fun:8090 {
    basic_auth {
        monitor $2a$14$3ElWtqrQmp9fknz0mEY5tuAgEER3fvTLeyAaJaED4d8I5NesPAjZy
    }

    handle {
        reverse_proxy localhost:19999 {
            header_up Host localhost
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}

