# piperchat environment variables
# copy to .env for local dev, or set in your process manager / container

# HTTP port to listen on (default 4100)
PORT=4100

# Directory where data files are stored (default: ./data)
DATA_DIR=./data

# SQLite database path (default: $DATA_DIR/piperchat.db)
# DB_PATH=./data/piperchat.db

# Optional PostHog project API key for telemetry.
# Events fired: message_posted, channel_created, key_first_seen.
# Leave unset (or empty) to disable telemetry entirely.
# POSTHOG_API_KEY=phc_your_key_here

# Comma-separated list of allowed CORS origins.
# Default is * (allow all). For production, restrict to your domain:
# ALLOWED_ORIGINS=https://chat.piedpiper.fun
ALLOWED_ORIGINS=*
